def temp_converter():
      temp= float(input("Enter the Reading:"))
      while True:
            print("Choose the Desired output")
            print('''
            1. Celsius to Kelvin
            2. Celsius to Fahrenheit
            3. Kelvin to Celsius
            4. Kelvin to Fahrenheit
            5. Fahrenheit to Celsius
            6. Fahrenheit to Kelvin
            ''')
            value= int(input("Enter the number associated with your desired change :"))
            converted = 0

            if value == 1: 
                  converted = temp+ 273.15
                  print (f"{temp}°C converted into {converted} K")
                  break
            elif value ==2 :
                  converted =(temp)*1.8 + 32
                  print (f"{temp}°C converted into {converted}°F")
                  break
            elif value == 3 :
                  converted=temp-273.15
                  print (f"{temp}K converted into {converted}°C")
                  break
            elif value == 4:
                  converted=(temp-273.15)*1.8 + 32
                  print (f"{temp}K converted into {converted}°F")
                  break
            elif value == 5:
                  converted=(temp -32)*5/9
                  print(f"{temp}°F converted to {converted}°C")
                  break
            elif value == 6:
                  converted= (temp-32)*5/9 + 273.15
                  print (f"{temp}°F converted to {converted}K")
                  break
            else:
                  print(" Enter a correct number from the menu")


temp_converter()
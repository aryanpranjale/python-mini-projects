import random

def no_of_rounds():
      
      print("Enter the number of rounds to play!")
      while True:
            round_choice= input("Press enter for 3 rounds else put a number :")
            user_round_choice = round_choice.strip()
            
            if user_round_choice== "" :
                  rounds= 3
                  return rounds
                  
            try:
                  rounds = int(user_round_choice)
                  if rounds > 0:
                        return rounds
                  elif rounds <0:
                        print("You have entered a negative number  , try again!")
                  else:
                        talk_1= ["Surely you are scared to be defeated by me!",
                                 "Try putting a actual number",
                                 "Do you call THAT a number?", 
                                 "Cant be bothered to win against a coward",
                                 "I am being nice, try again kiddo!",
                                 "So cute, stepping back even before playing!"]
                        talk = random.choice(talk_1)
                        print(talk)
                  
            except ValueError:
                  print ("Please enter a valid number or press enter, and try again!")
      




def score_counter(outcome, user_score,computer_score):
      
      if outcome == 0:
            print(f'Score {user_score} - {computer_score}')
      elif outcome==1:
            user_score += 1
            print(f'Score {user_score} - {computer_score}')
            
      elif outcome==2:
            computer_score += 1
            print(f'Score {user_score} - {computer_score}')
      return user_score, computer_score
      

            

            


def play_game():
      print("Welcome to The Game of ROCK PAPER SCISSORS")
      print("!!Warning!!\nNot for weak hearted people!")
      start_or_not = input('Enter Any key other than "1" to play:').strip()
      if start_or_not == "1":
            print("Saw it coming from a Mile!")
      else:
            setno= no_of_rounds()
            user_score=0
            computer_score=0
            for i in range (0, setno):
                  
                  user= user_input()
                  computer= computer_input()
                  play= face_off(user,computer)
                  score= score_counter(play,user_score,computer_score)
                  (user_score, computer_score)= score
            print(f' after {setno} rounds we have the scores {user_score}-{computer_score}')     

play_game()